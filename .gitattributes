# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.md text diff=markdown
*.ts text diff=typescript
*.js text diff=javascript
*.json text
*.html text diff=html
*.css text diff=css
*.yml text
*.yaml text

# Assets — Git LFS (will be activated when assets are added)
